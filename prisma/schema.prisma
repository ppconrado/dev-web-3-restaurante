// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  //output   = "../generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Pedido {
  // Configurção padrão e obrigatória para IDs no MongoDB usando prisma para o campo de ID
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  prato  String
  status String @default("preparando") // Forçamos o status inicial para "preparando" direto no DB
}

model Menu {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  item  String
  preco Float
}
